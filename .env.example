# Copy to .env and fill in the real values. .env always wins over
# config/settings.yaml when both set the same thing (core/factory.py).

# --- Azure OpenAI (required when llm.provider / embedding.provider: azure) ---
AOAI_API_KEY=

# Optional overrides of config/settings.yaml's llm/embedding sections:
# AOAI_API_ENDPOINT=https://skax.ai-talentlab.com
# AOAI_API_VERSION=2024-12-01-preview
# AOAI_MODEL_DEPLOYMENT=aitl-prd-gpt-5.4
# AOAI_EMBEDDING_MODEL_DEPLOYMENT=aitl-prd-text-embedding-3-small

# --- Qdrant (config/settings.yaml's qdrant.mode: local | cloud) ---
# Uncomment to switch modes without editing the config file:
# QDRANT_MODE=cloud
# QDRANT_URL=https://xyz.cloud.qdrant.io
# QDRANT_API_KEY=
# Qdrant
#QDRANT_URL=http://localhost:6333
QDRANT_URL=https://63354e74-5ca5-4c73-968b-d1c7793f78ae.us-west-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=


# --- API (api/app.py, optional) ---
# Path to a settings yaml other than config/settings.yaml, e.g. the offline
# fake config: WIKI_CONFIG_PATH=config/settings.fake.yaml
# WIKI_CONFIG_PATH=

# Port/host used by `python -m api.app` (uvicorn's own --port flag overrides
# this when running `uvicorn api.app:app` directly):
# API_PORT=8002
# API_HOST=127.0.0.1
